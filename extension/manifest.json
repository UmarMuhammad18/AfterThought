{
  "manifest_version": 3,
  "name": "AfterThought Recorder",
  "version": "1.0.0",
  "description": "Capture audio from the active tab for AfterThought transcription.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AfterThought Recorder"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}