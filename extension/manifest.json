{
  "manifest_version": 3,
  "name": "AfterThought",
  "version": "1.0.0",
  "description": "AI meeting assistant that records and uploads audio for processing.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AfterThought"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "microphone"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://afterthought.vercel.app/*"
  ]
}
